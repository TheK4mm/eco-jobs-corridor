# Plantilla de variables de entorno para PRODUCCIÓN (frontend).
# Vite inyecta estas variables EN TIEMPO DE BUILD (npm run build),
# por lo que deben estar definidas antes de compilar.

# URL pública de la API. Si sirves el frontend detrás del mismo
# dominio con un proxy inverso a la API (ver nginx.conf), usa una
# ruta relativa para evitar problemas de CORS:
#   VITE_API_URL=/api/v1
VITE_API_URL=https://api.tu-dominio.com/api/v1
