# ─────────────────────────────────────────────────────────────
# Configuración del servidor
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Origen permitido para CORS (URL del frontend). Separar varios con coma.
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Base de datos MySQL / MariaDB (XAMPP por defecto)
# En Windows usa 127.0.0.1 (no "localhost") para evitar el retraso
# de resolución IPv6 que puede causar timeouts de conexión.
# ─────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=corredor_empleo
# Base de datos usada por los tests de integración (se recrea en cada corrida)
DB_NAME_TEST=corredor_empleo_test

# ─────────────────────────────────────────────────────────────
# Autenticación JWT
# El secreto DEBE tener al menos 32 caracteres. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_de_32+_chars
JWT_EXPIRES_IN=3h

# ─────────────────────────────────────────────────────────────
# Usuario administrador inicial (lo crea el script de seed)
# ─────────────────────────────────────────────────────────────
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@corredorempleo.co
ADMIN_PASSWORD=Admin1234*
