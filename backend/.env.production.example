# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno para PRODUCCIÓN (backend)
# Copia a `.env` en el servidor o inyéctalas desde tu plataforma
# de despliegue / gestor de secretos. NUNCA subas valores reales.
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Dominio(s) reales del frontend (separar varios con coma).
CORS_ORIGIN=https://tu-dominio.com

# Base de datos gestionada (host/usuario/contraseña reales).
DB_HOST=tu-host-mysql
DB_PORT=3306
DB_USER=corredor
DB_PASSWORD=__define_una_contrasena_fuerte__
DB_NAME=corredor_empleo

# Secreto JWT (>= 64 caracteres recomendado). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=__genera_un_secreto_largo_y_aleatorio__
JWT_EXPIRES_IN=3h

# Administrador inicial. CÁMBIALO tras el primer arranque.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=__contrasena_admin_fuerte__
