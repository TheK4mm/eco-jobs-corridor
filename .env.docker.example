# Variables que consume docker-compose.yml.
# Copia a `.env` (en la raíz, junto al compose) antes de `docker compose up`.
# Este `.env` raíz está en .gitignore: NO lo subas con valores reales.

# Contraseña de root de MySQL dentro del contenedor.
DB_ROOT_PASSWORD=rootpass
DB_NAME=corredor_empleo

# Puerto del host para acceder a MySQL (debug) y al frontend.
DB_PORT_HOST=3307
FRONTEND_PORT=8080

# Secreto JWT (OBLIGATORIO, >= 32 caracteres). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_de_32+_chars
JWT_EXPIRES_IN=3h

# Debe coincidir con el origen público del frontend (puerto FRONTEND_PORT).
CORS_ORIGIN=http://localhost:8080

# Administrador inicial (se crea con `docker compose exec backend node dist/db/seed.js`).
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@corredorempleo.co
ADMIN_PASSWORD=Admin1234*
